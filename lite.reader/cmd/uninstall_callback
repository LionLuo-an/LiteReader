#!/bin/bash

LOG_FILE="${TRIM_PKGVAR}/uninstall.log"
echo "$(date) - Uninstall cleanup started" >> "${LOG_FILE}"

# 1. Kill by PID file if it exists
PID_FILE="${TRIM_PKGVAR}/app.pid"
if [ -f "$PID_FILE" ]; then
    PID=$(cat "$PID_FILE")
    if [ -n "$PID" ]; then
        echo "Found PID file with PID: $PID" >> "${LOG_FILE}"
        if kill -0 "$PID" 2>/dev/null; then
             echo "Killing process $PID..." >> "${LOG_FILE}"
             kill -9 "$PID" 2>/dev/null
        else
             echo "Process $PID not running." >> "${LOG_FILE}"
        fi
    fi
    rm -f "$PID_FILE"
fi

# 2. Aggressive cleanup of orphaned processes
# We search for 'node server.js' processes that are running from our app directory
echo "Scanning for orphaned processes..." >> "${LOG_FILE}"

# Get all PIDs matching "node server.js"
# We use pgrep -f to match the full command line
CANDIDATE_PIDS=$(pgrep -f "node server.js")

if [ -n "$CANDIDATE_PIDS" ]; then
    for pid in $CANDIDATE_PIDS; do
        # Skip self (unlikely, but good practice)
        if [ "$pid" == "$$" ]; then continue; fi
        
        # Check CWD of the process
        # We handle potential permission errors or missing /proc entries
        if [ -d "/proc/$pid" ]; then
            CWD=$(readlink "/proc/$pid/cwd" 2>/dev/null)
            
            # Check if CWD is within TRIM_APPDEST
            # TRIM_APPDEST is typically /var/packages/appname/target
            if [[ "$CWD" == "$TRIM_APPDEST"* ]]; then
                echo "Found orphan process $pid in $CWD. Killing..." >> "${LOG_FILE}"
                kill -9 "$pid" 2>/dev/null
            else
                echo "Skipping process $pid (CWD: $CWD)" >> "${LOG_FILE}"
            fi
        fi
    done
else
    echo "No node server.js processes found." >> "${LOG_FILE}"
fi

# 3. Force kill by port (Last Resort Safety Net)
# Only if we are absolutely sure about the port.
# But since the port is configurable, we might kill the wrong thing if we guess.
# However, we can check the default 8082 if it's still bound by a node process.

DEFAULT_PORT=8082
# Check if port 8082 is listened by a node process
PORT_PID=$(lsof -t -i:$DEFAULT_PORT -sTCP:LISTEN)
if [ -n "$PORT_PID" ]; then
    CMDLINE=$(cat /proc/$PORT_PID/cmdline 2>/dev/null)
    if [[ "$CMDLINE" == *"node"* ]] && [[ "$CMDLINE" == *"server.js"* ]]; then
         echo "Port $DEFAULT_PORT is still held by node process $PORT_PID. Killing..." >> "${LOG_FILE}"
         kill -9 "$PORT_PID" 2>/dev/null
    fi
fi

# Also check the user configured port if available in environment (unlikely in uninstall context)
# or read from config file?
# We'll skip that to avoid complexity. The CWD check is the most robust.

echo "Process cleanup completed." >> "${LOG_FILE}"

# ---------------------------------------------------------
# 4. 根据用户选择删除数据
# ---------------------------------------------------------
# wizard/uninstall 中的 delete_data 字段会作为环境变量传入
# 如果用户选择了删除数据选项，则清理数据目录

if [ "$delete_data" = "true" ]; then
    echo "User requested data deletion. Removing data directories..." >> "${LOG_FILE}"
    
    # 删除系统数据目录 (TRIM_PKGVAR = /volX/@appdata/appname)
    if [ -n "$TRIM_PKGVAR" ] && [ -d "$TRIM_PKGVAR" ]; then
        echo "Removing system data directory: $TRIM_PKGVAR" >> "${LOG_FILE}"
        rm -rf "$TRIM_PKGVAR"
    fi
    
    # 删除配置目录 (TRIM_PKGETC = /volX/@appconf/appname)
    if [ -n "$TRIM_PKGETC" ] && [ -d "$TRIM_PKGETC" ]; then
        echo "Removing config directory: $TRIM_PKGETC" >> "${LOG_FILE}"
        rm -rf "$TRIM_PKGETC"
    fi
    
    # 删除用户数据目录 (存储在共享文件夹中的 LightReader 目录)
    # 数据位置与 main 脚本保持一致
    USER_DATA_ROOT="${TRIM_DATA_SHARE_PATHS%%:*}"
    APP_SUBDIR="${wizard_data_subdir:-LightReader}"
    
    if [ -n "$USER_DATA_ROOT" ]; then
        USER_DATA_DIR="${USER_DATA_ROOT}/${APP_SUBDIR}"
        if [ -d "$USER_DATA_DIR" ]; then
            echo "Removing user data directory: $USER_DATA_DIR" >> "${LOG_FILE}"
            rm -rf "$USER_DATA_DIR"
        fi
    fi
    
    echo "Data deletion completed." >> "${LOG_FILE}"
else
    echo "User chose to keep data. Data directories preserved." >> "${LOG_FILE}"
fi

echo "Uninstall cleanup completed." >> "${LOG_FILE}"

exit 0
